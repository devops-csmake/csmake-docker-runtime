[~~phases~~]
clean=Remove all csmake generated files
package=Create the csmake-docker-runtime package
**sequences=
   clean -> package: build the csmake-docker-runtime install package
**default=clean -> package

# -----------------------------------------------------------------------
# Package metadata
# -----------------------------------------------------------------------
[metadata@csmake-docker-runtime]
name=csmake-docker-runtime
version=1.0.0
description=Pure-Python library for locating and invoking the Docker CLI
about=Provides the DockerRuntimeLibrary package, imported by csmake modules
 (such as csmake-ghactions) that need to run Docker containers as part
 of a build.
 .
 The docker binary is resolved from: docker= constructor arg, DOCKER_BIN
 env var, PATH, and common install paths including Docker Desktop on macOS.
 .
 Supports pre-built images or on-the-fly Dockerfile builds, with automatic
 host working-directory mounting, volume mounts, and environment injection.
 .
 This package is a pure library; it does not install any csmake modules.
 First-class csmake sections (DockerRuntime@...) will be provided by a
 separate csmake-docker-runtime-modules package in the future.
packager=Autumn Patterson <autumn@devops-csmake.com>
manufacturer=devops-csmake
depends=python3, csmake
keywords=make build development docker container library
url=https://github.com/devops-csmake/csmake-docker-runtime
copyrights=docker-runtime-copyright
classifiers=
    Development Status :: 4 - Beta
    Intended Audience :: Developers
    Topic :: Software Development :: Build Tools
    Programming Language :: Python :: 3
    License :: OSI Approved :: GNU General Public License v3 (GPLv3)
**files=
    <DockerRuntimeLibrary (python:library)> DockerRuntimeLibrary/*.py

