[~~phases~~]
clean=Remove all csmake generated files
package=Create the csmake-docker-runtime package
test=Run integration tests (requires Docker daemon)
**sequences=
   clean -> package: build the csmake-docker-runtime install package
**default=clean -> package

# -----------------------------------------------------------------------
# Package metadata
# -----------------------------------------------------------------------
[metadata@csmake-docker-runtime]
name=csmake-docker-runtime
version=1.0.0
description=csmake module for executing commands inside Docker containers
about=Provides the DockerRuntime csmake module, which discovers and invokes
 the Docker CLI to run containers or build images as part of a csmake build.
 .
 The docker binary is resolved from: --docker option, DOCKER_BIN env var,
 PATH, and common install paths including Docker Desktop on macOS.
 .
 Supports pre-built images (--image) or on-the-fly builds (--dockerfile),
 with automatic host working-directory mounting, volume mounts, and
 per-step environment variable injection.
packager=Autumn Patterson <autumn@devops-csmake.com>
manufacturer=devops-csmake
depends=python3, csmake
keywords=make build development docker container
url=https://github.com/devops-csmake/csmake-docker-runtime
copyrights=docker-runtime-copyright
classifiers=
    Development Status :: 4 - Beta
    Intended Audience :: Developers
    Topic :: Software Development :: Build Tools
    Programming Language :: Python :: 3
    License :: OSI Approved :: GNU General Public License v3 (GPLv3)
**files=
    <CsmakeModules (python:csmake-modules)> CsmakeModules/*.py

