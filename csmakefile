# -----------------------------------------------------------------------
# Install map
# -----------------------------------------------------------------------
[installmap@docker-runtime-installs]
path_root=INSTALL_ROOT
path_python-lib=PYTHON
owner_root=root
group_root=root

map_CsmakeModules=
   map: <CsmakeModules> -(1-1)-> {PYTHON}/CsmakeDockerRuntime/CsmakeModules/[~~file~~]
   copyright: docker-runtime-copyright
   owner:{root}
   group:{root}
   permissions:644

# -----------------------------------------------------------------------
# Versioning
# -----------------------------------------------------------------------
[versioning@snapshot-version]
designation=snapshot
format={datetime}.{gitSHA}
shell_datetime=date --utc +%%Y%%m%%d%%H%%M%%S
shell_gitSHA=git rev-parse HEAD

[versioning@rc-version]
designation=rc
format=rc{rc}
value_rc=1

# -----------------------------------------------------------------------
# Package targets
# -----------------------------------------------------------------------
[WheelPackage@wheel-docker-runtime]
package-version=1.0
top-level=CsmakeDockerRuntime
maps=docker-runtime-installs
result=%(RESULTS)s/wheelfile

[ZipPackager@zip-docker-runtime]
package-version=1.0
maps=docker-runtime-installs
result=%(RESULTS)s/zipfile

# -----------------------------------------------------------------------
# Integration tests  (require a running Docker daemon)
# -----------------------------------------------------------------------
[DockerRuntime@test-docker-version]
--image=alpine:3
--args=sh -c "echo csmake-docker-runtime OK && docker --version || true"
--workdir=/workspace

[DockerRuntime@test-docker-echo]
--image=alpine:3
--args=echo hello from csmake-docker-runtime

[command@test-docker-runtime]
description=Run integration tests (requires Docker daemon and network)
0000=test-docker-echo

[~~test~~]
00=test-docker-runtime

# -----------------------------------------------------------------------
# Build commands
# -----------------------------------------------------------------------
[command@default]
description=Create and package a csmake-docker-runtime release
00=csmake-docker-runtime, wheel-docker-runtime & zip-docker-runtime

[command@wheel-only]
description=Create a wheel package only
00=csmake-docker-runtime, wheel-docker-runtime

[command@zip-only]
description=Create a zip package only
00=csmake-docker-runtime, zip-docker-runtime

[command@snapshot]
description=Build a snapshot package
00=csmake-docker-runtime, snapshot-version, default

[command@rc]
description=Build a release candidate package
00=csmake-docker-runtime, rc-version, default
